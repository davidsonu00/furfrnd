<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>furfrnd | Auth</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
    crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #f6f7fb;
    }

    .registration-header {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .container {
      width: 90%;
      max-width: 1200px;
      margin: auto;
    }

    .logo, nav, .brand {
      display: flex;
      align-items: center;
    }

    .registration-header .container:first-child {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 20px 0;
    }

    .logo-text {
      font-size: 24px;
      font-weight: bold;
      color: #333;
    }

    nav ul {
      list-style: none;
      display: flex;
      gap: 20px;
      margin: 0;
      padding: 0;
    }

    nav a {
      text-decoration: none;
      color: #333;
      font-weight: 500;
    }

    .user-container {
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 75vh;
      padding: 30px 0;
    }

    .auth-container {
      width: 100%;
      max-width: 950px;
    }

    .auth-box,
    .otp-box,
    .forgot-box,
    .reset-otp-box,
    .reset-password-box {
      background: #fff;
      border-radius: 16px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.08);
      overflow: hidden;
      display: none;
    }

    .auth-box.active,
    .otp-box.active,
    .forgot-box.active,
    .reset-otp-box.active,
    .reset-password-box.active {
      display: block;
    }

    .grid-two--column {
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 520px;
    }

    .form-text {
      background: linear-gradient(135deg, #ff7a18, #ffb347);
      color: white;
      padding: 60px 40px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .form-text h2 {
      font-size: 32px;
      margin-bottom: 15px;
    }

    .form-text p {
      margin-bottom: 20px;
      line-height: 1.6;
    }

    .form-text button {
      width: fit-content;
      padding: 12px 22px;
      border: none;
      border-radius: 8px;
      background: white;
      color: #ff7a18;
      font-weight: bold;
      cursor: pointer;
    }

    .registration-form,
    .login-form,
    .single-form {
      padding: 45px 35px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .registration-form h2,
    .login-form h2,
    .single-form h2 {
      margin-bottom: 10px;
      color: #222;
    }

    .registration-form p,
    .login-form p,
    .single-form p {
      color: #666;
      margin-bottom: 18px;
    }

    .social-icons {
      display: flex;
      gap: 14px;
      margin-bottom: 18px;
    }

    .social-icons a {
      color: #555;
      font-size: 18px;
    }

    .input-field {
      margin-bottom: 16px;
    }

    .input-field input {
      width: 100%;
      padding: 14px 16px;
      border: 1px solid #ddd;
      border-radius: 10px;
      font-size: 15px;
      outline: none;
      box-sizing: border-box;
    }

    .input-field input:focus {
      border-color: #ff7a18;
    }

    .submit-btn {
      background: #ff7a18;
      color: white;
      border: none !important;
      cursor: pointer;
      font-weight: bold;
    }

    .submit-btn:hover {
      background: #ea6b10;
    }

    .forgot-password-link,
    .switch-link {
      color: #ff7a18;
      text-decoration: none;
      font-size: 14px;
      font-weight: 600;
    }

    .flash-message {
      margin-bottom: 16px;
      padding: 14px 18px;
      border-radius: 10px;
      font-size: 15px;
    }

    .success-flash {
      background: #eafaf1;
      color: #1e7e34;
      border: 1px solid #b7ebc6;
    }

    .error-flash {
      background: #fff0f0;
      color: #c0392b;
      border: 1px solid #f1b0b7;
    }

    .single-form-wrapper {
      max-width: 520px;
      margin: auto;
      padding: 45px 20px;
    }

    .single-form {
      min-height: auto;
    }

    .copyright {
      text-align: center;
      padding: 20px;
      color: #666;
      font-size: 14px;
    }

    @media (max-width: 768px) {
      .grid-two--column {
        grid-template-columns: 1fr;
      }

      nav ul {
        gap: 12px;
        flex-wrap: wrap;
        justify-content: flex-end;
      }

      .form-text,
      .registration-form,
      .login-form {
        padding: 30px 22px;
      }
    }
  </style>
</head>
<body>
  <header class="registration-header">
    <div class="container">
      <div class="logo">
        <div class="brand">
          <a href="/" style="text-decoration:none;">
            <span class="logo-text">🐶 furfrnd</span>
          </a>
        </div>
      </div>

      <nav>
        <% if (typeof user !== 'undefined' && user) { %>
          <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/shop">Shop</a></li>
            <li><a href="/register/logout">Logout</a></li>
          </ul>
        <% } else { %>
          <ul>
            <li><a href="/register">User Login</a></li>
            <li><a href="/admin/login">Admin Login</a></li>
            <li><a href="/shop">Shop</a></li>
            <li><a href="/">Home</a></li>
          </ul>
        <% } %>
      </nav>
    </div>

    <main>
      <section class="user-container">
        <div class="auth-container">
          <% if (typeof success !== 'undefined' && success && success.length) { %>
            <div class="flash-message success-flash">
              <%= success.join(', ') %>
            </div>
          <% } %>

          <% if (typeof error !== 'undefined' && error && error.length) { %>
            <div class="flash-message error-flash">
              <%= error.join(', ') %>
            </div>
          <% } %>

          <!-- REGISTER + LOGIN -->
          <div class="auth-box active" id="auth-box">
            <div class="registration" id="register-panel">
              <div class="grid-two--column">
                <div class="form-text">
                  <h2>Hello friend!</h2>
                  <p>To connect with us please login with your account.</p>
                  <button type="button" class="login-btn">Login here</button>
                </div>

                <div class="registration-form">
                  <h2>Create Account</h2>
                  <div class="social-icons">
                    <a href="https://discord.com/" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-discord"></i></a>
                    <a href="https://linkedin.com/" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-linkedin"></i></a>
                    <a href="https://instagram.com/" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-instagram"></i></a>
                    <a href="https://google.com/" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-google"></i></a>
                  </div>
                  <p>Or use your email for registration</p>

                  <form action="/register/register" method="POST">
                    <div class="input-field">
                      <input type="text" name="fullname" id="fullname" placeholder="Full Name" required>
                    </div>
                    <div class="input-field">
                      <input type="email" name="email" id="email" placeholder="Email" required autocomplete="email">
                    </div>
                    <div class="input-field">
                      <input type="password" name="password" id="password" placeholder="Password" required autocomplete="new-password">
                    </div>
                    <div class="input-field">
                      <input type="submit" value="Register" class="submit-btn">
                    </div>
                  </form>
                </div>
              </div>
            </div>

            <div class="login" id="login-panel" style="display:none;">
              <div class="grid-two--column">
                <div class="form-text">
                  <h2>Welcome back!</h2>
                  <p>Enter your personal details and continue your journey with us.</p>
                  <button type="button" class="registration-btn">Register here</button>
                </div>

                <div class="login-form">
                  <h2>Sign in</h2>
                  <div class="social-icons">
                    <a href="https://discord.com/" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-discord"></i></a>
                    <a href="https://linkedin.com/" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-linkedin"></i></a>
                    <a href="https://instagram.com/" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-instagram"></i></a>
                    <a href="https://google.com/" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-google"></i></a>
                  </div>
                  <p>Or use your account</p>

                  <form action="/register/login" method="POST">
                    <div class="input-field">
                      <input type="email" name="email" id="login-email" placeholder="Email" required autocomplete="email">
                    </div>
                    <div class="input-field">
                      <input type="password" name="password" id="login-password" placeholder="Password" required autocomplete="current-password">
                    </div>
                    <div class="input-field">
                      <a href="/register?modal=forgot" class="forgot-password-link">Forgot Password?</a>
                    </div>
                    <div class="input-field">
                      <input type="submit" value="Login" class="submit-btn">
                    </div>
                  </form>
                </div>
              </div>
            </div>
          </div>

          <!-- VERIFY REGISTRATION OTP -->
          <div class="otp-box" id="otp-box">
            <div class="single-form-wrapper">
              <div class="single-form">
                <h2>Verify your email</h2>
                <p>Enter the OTP sent to your email address.</p>
                <form action="/register/verify-otp" method="POST">
                  <div class="input-field">
                    <input type="email" name="email" id="otp-email" placeholder="Email" readonly required>
                  </div>
                  <div class="input-field">
                    <input type="text" name="otp" placeholder="Enter 6-digit OTP" required>
                  </div>
                  <div class="input-field">
                    <input type="submit" value="Verify OTP" class="submit-btn">
                  </div>
                </form>
                <a href="/register?modal=register" class="switch-link">Back to register</a>
              </div>
            </div>
          </div>

          <!-- FORGOT PASSWORD -->
          <div class="forgot-box" id="forgot-box">
            <div class="single-form-wrapper">
              <div class="single-form">
                <h2>Forgot Password</h2>
                <p>Enter your email to receive a reset OTP.</p>
                <form action="/register/forgot-password" method="POST">
                  <div class="input-field">
                    <input type="email" name="email" id="forgot-email" placeholder="Enter your email" required autocomplete="email">
                  </div>
                  <div class="input-field">
                    <input type="submit" value="Send Reset OTP" class="submit-btn">
                  </div>
                </form>
                <a href="/register?modal=user-login" class="switch-link">Back to login</a>
              </div>
            </div>
          </div>

          <!-- VERIFY RESET OTP -->
          <div class="reset-otp-box" id="reset-otp-box">
            <div class="single-form-wrapper">
              <div class="single-form">
                <h2>Verify reset OTP</h2>
                <p>Enter the OTP sent for password reset.</p>
                <form action="/register/verify-reset-otp" method="POST">
                  <div class="input-field">
                    <input type="email" name="email" id="reset-otp-email" placeholder="Email" readonly required>
                  </div>
                  <div class="input-field">
                    <input type="text" name="otp" placeholder="Enter reset OTP" required>
                  </div>
                  <div class="input-field">
                    <input type="submit" value="Verify Reset OTP" class="submit-btn">
                  </div>
                </form>
                <a href="/register?modal=forgot" class="switch-link">Back to forgot password</a>
              </div>
            </div>
          </div>

          <!-- RESET PASSWORD -->
          <div class="reset-password-box" id="reset-password-box">
            <div class="single-form-wrapper">
              <div class="single-form">
                <h2>Set New Password</h2>
                <p>Enter your new password below.</p>
                <form action="/register/reset-password" method="POST">
                  <div class="input-field">
                    <input type="email" name="email" id="new-password-email" placeholder="Email" readonly required>
                  </div>
                  <div class="input-field">
                    <input type="password" name="password" placeholder="New Password" required autocomplete="new-password">
                  </div>
                  <div class="input-field">
                    <input type="submit" value="Update Password" class="submit-btn">
                  </div>
                </form>
                <a href="/register?modal=user-login" class="switch-link">Back to login</a>
              </div>
            </div>
          </div>

        </div>
      </section>
    </main>

    <div class="foot-panel-4">
      <div class="copyright">
        ©2026, furfrnd. All rights reserved.
      </div>
    </div>
  </header>

  <script>
    const registerPanel = document.getElementById('register-panel');
    const loginPanel = document.getElementById('login-panel');

    const authBox = document.getElementById('auth-box');
    const otpBox = document.getElementById('otp-box');
    const forgotBox = document.getElementById('forgot-box');
    const resetOtpBox = document.getElementById('reset-otp-box');
    const resetPasswordBox = document.getElementById('reset-password-box');

    const regisBtn = document.querySelector('.registration-btn');
    const loginBtn = document.querySelector('.login-btn');

    function hideAllBoxes() {
      authBox.classList.remove('active');
      otpBox.classList.remove('active');
      forgotBox.classList.remove('active');
      resetOtpBox.classList.remove('active');
      resetPasswordBox.classList.remove('active');
    }

    function showRegister() {
      hideAllBoxes();
      authBox.classList.add('active');
      registerPanel.style.display = 'block';
      loginPanel.style.display = 'none';
    }

    function showLogin() {
      hideAllBoxes();
      authBox.classList.add('active');
      registerPanel.style.display = 'none';
      loginPanel.style.display = 'block';
    }

    regisBtn?.addEventListener('click', showRegister);
    loginBtn?.addEventListener('click', showLogin);

    const params = new URLSearchParams(window.location.search);
    const modal = params.get('modal');
    const step = params.get('step');
    const email = params.get('email');

    if (document.getElementById('otp-email')) {
      document.getElementById('otp-email').value = email || '';
    }
    if (document.getElementById('reset-otp-email')) {
      document.getElementById('reset-otp-email').value = email || '';
    }
    if (document.getElementById('new-password-email')) {
      document.getElementById('new-password-email').value = email || '';
    }
    if (document.getElementById('forgot-email') && email) {
      document.getElementById('forgot-email').value = email;
    }

    if (modal === 'register' && step === 'otp') {
      hideAllBoxes();
      otpBox.classList.add('active');
    } else if (modal === 'forgot') {
      hideAllBoxes();
      forgotBox.classList.add('active');
    } else if (modal === 'reset-otp') {
      hideAllBoxes();
      resetOtpBox.classList.add('active');
    } else if (modal === 'reset-password') {
      hideAllBoxes();
      resetPasswordBox.classList.add('active');
    } else if (modal === 'user-login') {
      showLogin();
    } else {
      showRegister();
    }

    setTimeout(() => {
      const flashes = document.querySelectorAll('.flash-message');
      flashes.forEach((flash) => {
        flash.style.transition = 'opacity 0.6s ease';
        flash.style.opacity = '0';
        setTimeout(() => flash.remove(), 600);
      });
    }, 4000);
  </script>
</body>
</html>