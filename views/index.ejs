<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Furfrnd - Find Your Perfect Companion</title>

  <!-- ✅ Tailwind built CSS -->
  <link rel="stylesheet" href="/css/style.css" />

  <!-- ✅ Font Awesome (keep this) -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>
<body class="bg-brand-cream text-slate-800">

  <%- include('partials/header') %>

  <main>
    <section class="relative overflow-hidden bg-[linear-gradient(rgba(42,168,168,0.72),rgba(42,168,168,0.72)),url('https://images.unsplash.com/photo-1587300003388-59208cc962cb?auto=format&fit=crop&w=1400&q=80')] bg-cover bg-center">
      <div class="mx-auto grid min-h-[78vh] max-w-7xl items-center gap-10 px-4 py-20 sm:px-6 lg:grid-cols-2 lg:px-8">
        <div class="text-white">
          <span class="inline-flex rounded-full border border-white/30 bg-white/10 px-4 py-2 text-sm font-semibold backdrop-blur-md">
            Trusted dogs. Trusted people. Trusted platform.
          </span>

          <h1 class="mt-6 text-4xl font-black leading-tight sm:text-5xl lg:text-6xl">
            Find a dog that feels like family from day one.
          </h1>

          <p class="mt-6 max-w-xl text-base leading-7 text-white/90 sm:text-lg">
            Browse healthy, verified dogs, shop with confidence, and manage everything in one beautiful experience for buyers and admin.
          </p>

          <div class="mt-8 flex flex-wrap gap-4">
            <a href="/shop" class="rounded-full bg-white px-6 py-3 text-sm font-bold text-teal-700 transition hover:bg-slate-100">
              Explore Dogs
            </a>
            <% if (!user) { %>
              <button type="button" data-open-modal="register" class="rounded-full border border-white/40 bg-white/10 px-6 py-3 text-sm font-bold text-white backdrop-blur transition hover:bg-white/20">
                Join the Pack
              </button>
            <% } %>
          </div>
        </div>

        <div class="rounded-[32px] border border-white/20 bg-white/10 p-4 shadow-soft backdrop-blur-md">
          <div id="carouselDogs" class="relative overflow-hidden rounded-[28px]">
            <div class="carousel-slides relative h-[420px]">
              <div class="carousel-item absolute inset-0 block">
                <img src="https://images.squarespace-cdn.com/content/v1/54e7a1a6e4b08db9da801ded/1bd563c1-7bbb-4b44-af21-a60408b6f129/44.png" alt="Jimmy German Shepherd" class="h-full w-full object-cover" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                <div class="absolute bottom-6 left-6 rounded-full bg-white/15 px-5 py-2 text-sm font-bold text-white backdrop-blur-md">
                  Jimmy — German Shepherd
                </div>
              </div>

              <div class="carousel-item absolute inset-0 hidden">
                <img src="https://images.unsplash.com/photo-1507146426996-ef05306b995a?auto=format&fit=crop&w=1200&q=80" alt="Bella Beagle" class="h-full w-full object-cover" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                <div class="absolute bottom-6 left-6 rounded-full bg-white/15 px-5 py-2 text-sm font-bold text-white backdrop-blur-md">
                  Bella — Beagle
                </div>
              </div>

              <div class="carousel-item absolute inset-0 hidden">
                <img src="https://images.unsplash.com/photo-1552053831-71594a27632d?auto=format&fit=crop&w=1200&q=80" alt="Lily Golden Retriever" class="h-full w-full object-cover" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                <div class="absolute bottom-6 left-6 rounded-full bg-white/15 px-5 py-2 text-sm font-bold text-white backdrop-blur-md">
                  Lily — Golden Retriever
                </div>
              </div>
            </div>

            <button id="prevSlide" type="button" class="absolute left-4 top-1/2 z-10 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full bg-rose-400 text-white shadow-lg transition hover:scale-105">
              <i class="fas fa-chevron-left"></i>
            </button>

            <button id="nextSlide" type="button" class="absolute right-4 top-1/2 z-10 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full bg-rose-400 text-white shadow-lg transition hover:scale-105">
              <i class="fas fa-chevron-right"></i>
            </button>
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
      <div class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr]">
        <div class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-soft sm:p-8">
          <h2 class="text-3xl font-black text-slate-900">Featured Puppy Details</h2>
          <p class="mt-3 max-w-2xl text-slate-600">
            A closer look at one of our most loved featured companions.
          </p>

          <div class="mt-8 grid gap-6 md:grid-cols-2">
            <div>
              <h3 id="breed-name" class="text-2xl font-extrabold text-teal-700">Jimmy — German Shepherd</h3>
              <p id="breed-price" class="mt-3 text-3xl font-black text-slate-900">₹45,000</p>
            </div>

            <div class="grid gap-3">
              <div id="breed-age" class="rounded-2xl bg-slate-50 px-4 py-3 text-sm font-medium text-slate-700">
                <strong>Age:</strong> 12 weeks
              </div>
              <div id="breed-vaccinations" class="rounded-2xl bg-slate-50 px-4 py-3 text-sm font-medium text-slate-700">
                <strong>Vaccinations:</strong> Complete
              </div>
              <div id="breed-size" class="rounded-2xl bg-slate-50 px-4 py-3 text-sm font-medium text-slate-700">
                <strong>Size:</strong> Medium (25-35 kg)
              </div>
            </div>
          </div>

          <div class="mt-8">
            <h4 class="text-sm font-extrabold uppercase tracking-[0.18em] text-slate-500">Key Features</h4>
            <div id="breed-traits" class="mt-4 flex flex-wrap gap-2">
              <span class="rounded-full bg-teal-50 px-4 py-2 text-sm font-semibold text-teal-700">Family-friendly</span>
              <span class="rounded-full bg-teal-50 px-4 py-2 text-sm font-semibold text-teal-700">High Energy</span>
              <span class="rounded-full bg-teal-50 px-4 py-2 text-sm font-semibold text-teal-700">Easy Training</span>
            </div>
          </div>

          <div class="mt-8">
            <a href="/shop" class="inline-flex items-center rounded-full bg-teal-700 px-6 py-3 text-sm font-bold text-white transition hover:bg-teal-800">
              Shop Now
            </a>
          </div>
        </div>

        <div class="grid gap-6">
          <div class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-soft">
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-teal-50 text-2xl text-teal-700">
              <i class="fas fa-shield-dog"></i>
            </div>
            <h3 class="mt-5 text-xl font-extrabold text-slate-900">Verified listings</h3>
            <p class="mt-3 text-sm leading-6 text-slate-600">
              Showcase dogs with clear details, pricing, and trust-focused presentation for your buyers.
            </p>
          </div>

          <div class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-soft">
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-rose-50 text-2xl text-rose-500">
              <i class="fas fa-cart-shopping"></i>
            </div>
            <h3 class="mt-5 text-xl font-extrabold text-slate-900">Smooth shopping flow</h3>
            <p class="mt-3 text-sm leading-6 text-slate-600">
              Let users register, login, add dogs to cart, and place orders in one connected experience.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-white py-16">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center">
          <h2 class="text-3xl font-black text-slate-900 sm:text-4xl">Why Choose Furfrnd?</h2>
          <p class="mx-auto mt-4 max-w-2xl text-slate-600">
            Built for trust, clarity, and a warm adoption experience.
          </p>
        </div>

        <div class="mt-12 grid gap-6 md:grid-cols-3">
          <div class="rounded-[28px] border border-slate-200 bg-slate-50 p-8">
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-teal-100 text-teal-700">
              <i class="fas fa-dog"></i>
            </div>
            <h3 class="mt-5 text-xl font-extrabold text-slate-900">Trusted Breeders</h3>
            <p class="mt-3 text-sm leading-6 text-slate-600">
              Every dog listing can be shown with proper details, trust signals, and ethical presentation.
            </p>
          </div>

          <div class="rounded-[28px] border border-slate-200 bg-slate-50 p-8">
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-rose-100 text-rose-500">
              <i class="fas fa-users"></i>
            </div>
            <h3 class="mt-5 text-xl font-extrabold text-slate-900">Real Community</h3>
            <p class="mt-3 text-sm leading-6 text-slate-600">
              Create a friendly destination where dog lovers discover pets and return with confidence.
            </p>
          </div>

          <div class="rounded-[28px] border border-slate-200 bg-slate-50 p-8">
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-amber-100 text-amber-500">
              <i class="fas fa-heart-circle-check"></i>
            </div>
            <h3 class="mt-5 text-xl font-extrabold text-slate-900">Health & Care Focus</h3>
            <p class="mt-3 text-sm leading-6 text-slate-600">
              Show vaccination, age, breed traits, and support details in a clean buyer-friendly way.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>

  <%- include('partials/auth-modals') %>

  <!-- <% const flashSuccess = success && success.length ? success[0] : null; %>
  <% const flashError = error && error.length ? error[0] : null; %>
  <% const currentModal = modal || ''; %>
  <% const currentEmail = email || ''; %>

  <div id="modalOverlay" class="pointer-events-none fixed inset-0 z-[100] hidden items-center justify-center bg-slate-950/40 p-4 backdrop-blur-md">
    <div data-modal="register" class="modal-panel hidden w-full max-w-md rounded-[28px] bg-white p-6 shadow-soft">
      <div class="flex items-start justify-between">
        <div>
          <h3 class="text-2xl font-black text-slate-900">Create account</h3>
          <p class="mt-2 text-sm text-slate-500">Join Furfrnd and start your journey.</p>
        </div>
        <button type="button" class="close-modal rounded-xl p-2 text-slate-500 hover:bg-slate-100">
          <i class="fas fa-xmark"></i>
        </button>
      </div>

      <% if (flashSuccess && currentModal === 'register') { %>
        <div class="mt-4 rounded-2xl bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-700"><%= flashSuccess %></div>
      <% } %>
      <% if (flashError && currentModal === 'register') { %>
        <div class="mt-4 rounded-2xl bg-rose-50 px-4 py-3 text-sm font-medium text-rose-700"><%= flashError %></div>
      <% } %>

      <form action="/register/register" method="POST" class="mt-6 space-y-4">
        <div>
          <label class="mb-2 block text-sm font-semibold text-slate-700">Full name</label>
          <input type="text" name="fullname" required class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-teal-500" placeholder="Enter your full name" />
        </div>
        <div>
          <label class="mb-2 block text-sm font-semibold text-slate-700">Email</label>
          <input type="email" name="email" required class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-teal-500" placeholder="Enter your email" />
        </div>
        <div>
          <label class="mb-2 block text-sm font-semibold text-slate-700">Password</label>
          <input type="password" name="password" required class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-teal-500" placeholder="Create a password" />
        </div>
        <button type="submit" class="w-full rounded-2xl bg-teal-700 px-4 py-3 text-sm font-bold text-white transition hover:bg-teal-800">
          Register
        </button>
      </form>

      <div class="mt-4 text-center text-sm text-slate-500">
        Already have an account?
        <button type="button" data-switch-modal="user-login" class="font-semibold text-teal-700 hover:underline">Login</button>
      </div>
    </div>

    <div data-modal="otp" class="modal-panel hidden w-full max-w-md rounded-[28px] bg-white p-6 shadow-soft">
      <div class="flex items-start justify-between">
        <div>
          <h3 class="text-2xl font-black text-slate-900">Verify email</h3>
          <p class="mt-2 text-sm text-slate-500">Enter the OTP sent to your email.</p>
        </div>
        <button type="button" class="close-modal rounded-xl p-2 text-slate-500 hover:bg-slate-100">
          <i class="fas fa-xmark"></i>
        </button>
      </div>

      <% if (flashSuccess && currentModal === 'otp') { %>
        <div class="mt-4 rounded-2xl bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-700"><%= flashSuccess %></div>
      <% } %>
      <% if (flashError && currentModal === 'otp') { %>
        <div class="mt-4 rounded-2xl bg-rose-50 px-4 py-3 text-sm font-medium text-rose-700"><%= flashError %></div>
      <% } %>

      <form action="/register/verify-otp" method="POST" class="mt-6 space-y-4">
        <div>
          <label class="mb-2 block text-sm font-semibold text-slate-700">Email</label>
          <input type="email" name="email" value="<%= currentEmail %>" readonly required class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm outline-none" />
        </div>
        <div>
          <label class="mb-2 block text-sm font-semibold text-slate-700">OTP</label>
          <input type="text" name="otp" required maxlength="6" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-teal-500" placeholder="Enter 6-digit OTP" />
        </div>
        <button type="submit" class="w-full rounded-2xl bg-teal-700 px-4 py-3 text-sm font-bold text-white transition hover:bg-teal-800">
          Verify OTP
        </button>
      </form>

      <div class="mt-4 text-center text-sm text-slate-500">
        Back to
        <button type="button" data-switch-modal="register" class="font-semibold text-teal-700 hover:underline">Register</button>
      </div>
    </div>

    <div data-modal="user-login" class="modal-panel hidden w-full max-w-md rounded-[28px] bg-white p-6 shadow-soft">
      <div class="flex items-start justify-between">
        <div>
          <h3 class="text-2xl font-black text-slate-900">User login</h3>
          <p class="mt-2 text-sm text-slate-500">Welcome back to Furfrnd.</p>
        </div>
        <button type="button" class="close-modal rounded-xl p-2 text-slate-500 hover:bg-slate-100">
          <i class="fas fa-xmark"></i>
        </button>
      </div>

      <% if (flashSuccess && currentModal === 'user-login') { %>
        <div class="mt-4 rounded-2xl bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-700"><%= flashSuccess %></div>
      <% } %>
      <% if (flashError && currentModal === 'user-login') { %>
        <div class="mt-4 rounded-2xl bg-rose-50 px-4 py-3 text-sm font-medium text-rose-700"><%= flashError %></div>
      <% } %>

      <form action="/register/login" method="POST" class="mt-6 space-y-4">
        <div>
          <label class="mb-2 block text-sm font-semibold text-slate-700">Email</label>
          <input type="email" name="email" required class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-teal-500" placeholder="Enter your email" />
        </div>
        <div>
          <label class="mb-2 block text-sm font-semibold text-slate-700">Password</label>
          <input type="password" name="password" required class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-teal-500" placeholder="Enter your password" />
        </div>
        <button type="submit" class="w-full rounded-2xl bg-teal-700 px-4 py-3 text-sm font-bold text-white transition hover:bg-teal-800">
          Login
        </button>
      </form>

      <div class="mt-4 flex items-center justify-between text-sm">
        <button type="button" data-switch-modal="forgot" class="font-semibold text-teal-700 hover:underline">Forgot password?</button>
        <button type="button" data-switch-modal="register" class="font-semibold text-teal-700 hover:underline">Create account</button>
      </div>
    </div>

    <div data-modal="forgot" class="modal-panel hidden w-full max-w-md rounded-[28px] bg-white p-6 shadow-soft">
      <div class="flex items-start justify-between">
        <div>
          <h3 class="text-2xl font-black text-slate-900">Forgot password</h3>
          <p class="mt-2 text-sm text-slate-500">Enter your email to receive a reset OTP.</p>
        </div>
        <button type="button" class="close-modal rounded-xl p-2 text-slate-500 hover:bg-slate-100">
          <i class="fas fa-xmark"></i>
        </button>
      </div>

      <% if (flashSuccess && currentModal === 'forgot') { %>
        <div class="mt-4 rounded-2xl bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-700"><%= flashSuccess %></div>
      <% } %>
      <% if (flashError && currentModal === 'forgot') { %>
        <div class="mt-4 rounded-2xl bg-rose-50 px-4 py-3 text-sm font-medium text-rose-700"><%= flashError %></div>
      <% } %>

      <form action="/register/forgot-password" method="POST" class="mt-6 space-y-4">
        <div>
          <label class="mb-2 block text-sm font-semibold text-slate-700">Email</label>
          <input type="email" name="email" value="<%= currentEmail %>" required class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-teal-500" placeholder="Enter your email" />
        </div>
        <button type="submit" class="w-full rounded-2xl bg-teal-700 px-4 py-3 text-sm font-bold text-white transition hover:bg-teal-800">
          Send Reset OTP
        </button>
      </form>

      <div class="mt-4 text-center text-sm text-slate-500">
        Back to
        <button type="button" data-switch-modal="user-login" class="font-semibold text-teal-700 hover:underline">Login</button>
      </div>
    </div>

    <div data-modal="reset-otp" class="modal-panel hidden w-full max-w-md rounded-[28px] bg-white p-6 shadow-soft">
      <div class="flex items-start justify-between">
        <div>
          <h3 class="text-2xl font-black text-slate-900">Verify reset OTP</h3>
          <p class="mt-2 text-sm text-slate-500">Enter the OTP sent for password reset.</p>
        </div>
        <button type="button" class="close-modal rounded-xl p-2 text-slate-500 hover:bg-slate-100">
          <i class="fas fa-xmark"></i>
        </button>
      </div>

      <% if (flashSuccess && currentModal === 'reset-otp') { %>
        <div class="mt-4 rounded-2xl bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-700"><%= flashSuccess %></div>
      <% } %>
      <% if (flashError && currentModal === 'reset-otp') { %>
        <div class="mt-4 rounded-2xl bg-rose-50 px-4 py-3 text-sm font-medium text-rose-700"><%= flashError %></div>
      <% } %>

      <form action="/register/verify-reset-otp" method="POST" class="mt-6 space-y-4">
        <div>
          <label class="mb-2 block text-sm font-semibold text-slate-700">Email</label>
          <input type="email" name="email" value="<%= currentEmail %>" readonly required class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm outline-none" />
        </div>
        <div>
          <label class="mb-2 block text-sm font-semibold text-slate-700">OTP</label>
          <input type="text" name="otp" required maxlength="6" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-teal-500" placeholder="Enter reset OTP" />
        </div>
        <button type="submit" class="w-full rounded-2xl bg-teal-700 px-4 py-3 text-sm font-bold text-white transition hover:bg-teal-800">
          Verify Reset OTP
        </button>
      </form>

      <div class="mt-4 text-center text-sm text-slate-500">
        Back to
        <button type="button" data-switch-modal="forgot" class="font-semibold text-teal-700 hover:underline">Forgot password</button>
      </div>
    </div>

    <div data-modal="reset-password" class="modal-panel hidden w-full max-w-md rounded-[28px] bg-white p-6 shadow-soft">
      <div class="flex items-start justify-between">
        <div>
          <h3 class="text-2xl font-black text-slate-900">Set new password</h3>
          <p class="mt-2 text-sm text-slate-500">Enter your new password below.</p>
        </div>
        <button type="button" class="close-modal rounded-xl p-2 text-slate-500 hover:bg-slate-100">
          <i class="fas fa-xmark"></i>
        </button>
      </div>

      <% if (flashSuccess && currentModal === 'reset-password') { %>
        <div class="mt-4 rounded-2xl bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-700"><%= flashSuccess %></div>
      <% } %>
      <% if (flashError && currentModal === 'reset-password') { %>
        <div class="mt-4 rounded-2xl bg-rose-50 px-4 py-3 text-sm font-medium text-rose-700"><%= flashError %></div>
      <% } %>

      <form action="/register/reset-password" method="POST" class="mt-6 space-y-4">
        <div>
          <label class="mb-2 block text-sm font-semibold text-slate-700">Email</label>
          <input type="email" name="email" value="<%= currentEmail %>" readonly required class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm outline-none" />
        </div>
        <div>
          <label class="mb-2 block text-sm font-semibold text-slate-700">New password</label>
          <input type="password" name="password" required class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-teal-500" placeholder="Enter new password" />
        </div>
        <button type="submit" class="w-full rounded-2xl bg-teal-700 px-4 py-3 text-sm font-bold text-white transition hover:bg-teal-800">
          Update Password
        </button>
      </form>

      <div class="mt-4 text-center text-sm text-slate-500">
        Back to
        <button type="button" data-switch-modal="user-login" class="font-semibold text-teal-700 hover:underline">Login</button>
      </div>
    </div>

    <div data-modal="admin-login" class="modal-panel hidden w-full max-w-md rounded-[28px] bg-white p-6 shadow-soft">
      <div class="flex items-start justify-between">
        <div>
          <h3 class="text-2xl font-black text-slate-900">Admin login</h3>
          <p class="mt-2 text-sm text-slate-500">Access the admin dashboard.</p>
        </div>
        <button type="button" class="close-modal rounded-xl p-2 text-slate-500 hover:bg-slate-100">
          <i class="fas fa-xmark"></i>
        </button>
      </div>

