<!DOCTYPE html>
<html><head>
    <link rel="stylesheet" href="/css/styles.css">
    <title>Forgot Password - furfrnd</title>
</head><body>
    <div class="container">
        <h2>Forgot Password?</h2>
        <% if (typeof error !== 'undefined' && error && error.length) { %>
            <div class="flash-message error-flash"><%= error.join(', ') %></div>
        <% } %>
        <% if (typeof success !== 'undefined' && success && success.length) { %>
            <div class="flash-message success-flash"><%= success.join(', ') %></div>
        <% } %>
        <form action="/register/forgot-password" method="POST">
            <input type="email" name="email" placeholder="Enter your email" required>
            <button type="submit">Send Reset OTP</button>
        </form>
        <a href="/register">← Back to Login</a>
    </div>
</body></html>