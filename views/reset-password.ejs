<!DOCTYPE html>
<html><head>
    <link rel="stylesheet" href="/css/styles.css">
    <title>Reset Password - furfrnd</title>
</head><body>
    <div class="container">
        <h2>Set New Password</h2>
        <% if (typeof error !== 'undefined' && error && error.length) { %>
            <div class="flash-message error-flash"><%= error.join(', ') %></div>
        <% } %>
        <% if (typeof success !== 'undefined' && success && success.length) { %>
            <div class="flash-message success-flash"><%= success.join(', ') %></div>
        <% } %>
        <form action="/register/reset-password" method="POST">
            <input type="hidden" name="email" value="<%= email || '' %>">
            <input type="password" name="password" placeholder="New password" required>
            <button type="submit">Update Password</button>
        </form>
        <a href="/register">← Back to Login</a>
    </div>
</body></html>