<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Furfrnd - Home</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        :root {
            --primary: #2AA8A8;
            --secondary: #FF6B6B;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: #f8f9fa;
            overflow-x: hidden;
        }

        .logo-text {
            font-family: 'Quicksand', sans-serif;
            font-size: 2rem;
            color: #2AA8A8;
            font-weight: 600;
            letter-spacing: 1px;
            background: linear-gradient(45deg, #2AA8A8, #FF6B6B);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero-about {
            background: linear-gradient(rgba(42, 168, 168, 0.9), rgba(42, 168, 168, 0.8)),
                url('https://images.unsplash.com/photo-1583511655857-d19b40a7a54e') center/cover;
            height: 50vh;
            display: flex;
            align-items: center;
            color: white;
        }

        .nav-link {
            color: var(--primary) !important;
            font-weight: 500;
        }

        .nav-link:hover {
            color: var(--secondary) !important;
        }

        /* Modal Overlay */
        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(10px);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            animation: fadeIn 0.3s ease;
        }

        .modal-overlay.active {
            display: flex;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        .modal-box {
            width: 100%;
            max-width: 420px;
            background: white;
            border-radius: 20px;
            padding: 40px;
            box-shadow: 0 25px 60px rgba(0,0,0,0.25);
            transform: scale(0.8);
            animation: modalPop 0.3s ease forwards;
            position: relative;
        }

        @keyframes modalPop {
            to {
                transform: scale(1);
            }
        }

        .modal-box h2 {
            color: var(--primary);
            margin-bottom: 20px;
            font-weight: 700;
        }

        .input-field {
            position: relative;
            margin-bottom: 20px;
        }

        .input-field input {
            width: 100%;
            padding: 15px 20px;
            border: 2px solid #e1e5e9;
            border-radius: 12px;
            font-size: 16px;
            transition: all 0.3s ease;
            background: #f8f9fa;
        }

        .input-field input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(42, 168, 168, 0.1);
            background: white;
        }

        .submit-btn {
            width: 100%;
            padding: 15px;
            border: none;
            border-radius: 12px;
            background: linear-gradient(45deg, var(--primary), var(--secondary));
            color: white;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s ease;
        }

        .submit-btn:hover {
            transform: translateY(-2px);
        }

        .close-btn {
            position: absolute;
            top: 15px;
            right: 20px;
            background: none;
            border: none;
            font-size: 24px;
            color: #999;
            cursor: pointer;
        }

        .close-btn:hover {
            color: #666;
        }

        .flash-message {
            padding: 12px 16px;
            border-radius: 10px;
            margin-bottom: 20px;
            font-size: 14px;
        }

        .success-flash {
            background: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }

        .error-flash {
            background: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }

        .login-dropdown {
            position: relative;
        }

        .dropdown-menu {
            position: absolute;
            top: 100%;
            right: 0;
            background: white;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.15);
            min-width: 180px;
            opacity: 0;
            visibility: hidden;
            transform: translateY(-10px);
            transition: all 0.3s ease;
            z-index: 1000;
        }

        .login-dropdown:hover .dropdown-menu {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

        .dropdown-menu a {
            display: block;
            padding: 12px 20px;
            color: #333;
            text-decoration: none;
            border-radius: 8px;
            transition: background 0.2s ease;
        }

        .dropdown-menu a:hover {
            background: #f8f9fa;
        }

        .otp-section {
            display: none;
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid #e1e5e9;
        }

        .otp-section.active {
            display: block;
            animation: slideDown 0.3s ease;
        }

        @keyframes slideDown {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .tab-buttons {
            display: flex;
            gap: 10px;
            margin-bottom: 25px;
        }

        .tab-btn {
            flex: 1;
            padding: 12px;
            border: 2px solid #e1e5e9;
            background: none;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .tab-btn.active {
            border-color: var(--primary);
            background: var(--primary);
            color: white;
        }
    </style>
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light bg-light px-3">
        <a class="logo-text navbar-brand" href="/">
            🐶 furfrnd
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                    <a class="nav-link" href="/shop">Shop</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#" id="openRegister">Register</a>
                </li>
                <li class="nav-item login-dropdown">
                    <a class="nav-link" href="#">Login</a>
                    <div class="dropdown-menu">
                        <a href="#" id="openUserLogin">Login as User</a>
                        <a href="#" id="openAdminLogin">Login as Admin</a>
                    </div>
                </li>
            </ul>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero-about">
        <div class="container text-center">
            <h1 class="display-5 fw-bold">More Than Just a Pet Platform</h1>
            <p class="lead">Connecting loving homes with happy paws since 2023</p>
        </div>
    </section>

    <!-- Your existing content sections stay the same -->
    <!-- Our Story, Core Values, Team Section, Footer... -->

    <!-- Register Modal -->
    <div class="modal-overlay" id="registerModal">
        <div class="modal-box">
            <button class="close-btn" id="closeRegister">&times;</button>
            <h2><i class="fas fa-user-plus"></i> Create Account</h2>
            
            <% if (typeof success !== 'undefined' && success && success.length) { %>
                <div class="flash-message success-flash"><%= success.join(', ') %></div>
            <% } %>
            <% if (typeof error !== 'undefined' && error && error.length) { %>
                <div class="flash-message error-flash"><%= error.join(', ') %></div>
            <% } %>

            <form id="registerForm" action="/register/register" method="POST">
                <div class="input-field">
                    <input type="text" name="fullname" placeholder="Full Name" required>
                </div>
                <div class="input-field">
                    <input type="email" name="email" id="registerEmail" placeholder="Email" required>
                </div>
                <div class="input-field">
                    <input type="password" name="password" placeholder="Password" required>
                </div>
                
                <div class="otp-section" id="registerOtpSection">
                    <input type="text" name="otp" placeholder="Enter 6-digit OTP" maxlength="6" required>
                    <small style="color: #666;">Check your email for OTP</small>
                </div>

                <button type="submit" class="submit-btn">
                    <span id="registerBtnText">Register</span>
                </button>
            </form>
        </div>
    </div>

    <!-- User Login Modal -->
    <div class="modal-overlay" id="userLoginModal">
        <div class="modal-box">
            <button class="close-btn" id="closeUserLogin">&times;</button>
            <h2><i class="fas fa-sign-in-alt"></i> User Login</h2>
            
            <% if (typeof success !== 'undefined' && success && success.length) { %>
                <div class="flash-message success-flash"><%= success.join(', ') %></div>
            <% } %>
            <% if (typeof error !== 'undefined' && error && error.length) { %>
                <div class="flash-message error-flash"><%= error.join(', ') %></div>
            <% } %>

            <form action="/register/login" method="POST">
                <div class="input-field">
                    <input type="email" name="email" placeholder="Email" required>
                </div>
                <div class="input-field">
                    <input type="password" name="password" placeholder="Password" required>
                </div>
                <div class="input-field">
                    <a href="/register/forgot-password" style="color: var(--primary); font-size: 14px;">Forgot Password?</a>
                </div>
                <button type="submit" class="submit-btn">Login</button>
            </form>
        </div>
    </div>

    <!-- Admin Login Modal -->
    <div class="modal-overlay" id="adminLoginModal">
        <div class="modal-box">
            <button class="close-btn" id="closeAdminLogin">&times;</button>
            <h2><i class="fas fa-user-shield"></i> Admin Login</h2>
            
            <% if (typeof success !== 'undefined' && success && success.length) { %>
                <div class="flash-message success-flash"><%= success.join(', ') %></div>
            <% } %>
            <% if (typeof error !== 'undefined' && error && error.length) { %>
                <div class="flash-message error-flash"><%= error.join(', ') %></div>
            <% } %>

            <form action="/admin/login" method="POST">
                <div class="input-field">
                    <input type="email" name="email" placeholder="Admin Email" required>
                </div>
                <div class="input-field">
                    <input type="password" name="password" placeholder="Password" required>
                </div>
                <button type="submit" class="submit-btn">Admin Login</button>
            </div>
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Modal controls
        document.getElementById('openRegister').onclick = () => {
            document.getElementById('registerModal').classList.add('active');
        };

        document.getElementById('openUserLogin').onclick = (e) => {
            e.preventDefault();
            document.getElementById('userLoginModal').classList.add('active');
            document.querySelector('.login-dropdown .dropdown-menu').style.display = 'none';
        };

        document.getElementById('openAdminLogin').onclick = (e) => {
            e.preventDefault();
            document.getElementById('adminLoginModal').classList.add('active');
            document.querySelector('.login-dropdown .dropdown-menu').style.display = 'none';
        };

        // Close modals
        document.querySelectorAll('.close-btn').forEach(btn => {
            btn.onclick = () => {
                btn.closest('.modal-overlay').classList.remove('active');
            }
        });

        // Close on overlay click
        document.querySelectorAll('.modal-overlay').forEach(overlay => {
            overlay.onclick = (e) => {
                if (e.target === overlay) {
                    overlay.classList.remove('active');
                }
            }
        });

        // OTP handling for register
        let otpSent = false;
        document.getElementById('registerForm').onsubmit = async (e) => {
            if (!otpSent) {
                // First submission - register
                otpSent = true;
                document.getElementById('registerBtnText').textContent = 'Verify OTP';
                document.getElementById('registerOtpSection').classList.add('active');
                e.preventDefault();
                return false;
            }
            // Second submission - verify OTP
            return true;
        };

        // Auto-hide flash messages
        setTimeout(() => {
            document.querySelectorAll('.flash-message').forEach(msg => {
                msg.style.transition = 'opacity 0.5s';
                msg.style.opacity = '0';
                setTimeout(() => msg.remove(), 500);
            });
        }, 5000);

        // Dropdown positioning fix
        document.querySelector('.login-dropdown').onmouseenter = () => {
            document.querySelector('.dropdown-menu').style.display = 'block';
        };
        document.querySelector('.login-dropdown').onmouseleave = () => {
            document.querySelector('.dropdown-menu').style.display = 'none';
        };
    </script>
</body>
</html>