<header class="sticky top-0 z-50 border-b border-slate-200 bg-white/95 backdrop-blur">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
    <a href="/" class="flex items-center gap-3">
      <span class="text-4xl leading-none">🐶</span>
      <span class="text-3xl font-black tracking-tight text-teal-700">furfrnd</span>
    </a>

    <nav class="hidden items-center gap-8 md:flex">
      <a href="/" class="text-sm font-semibold text-slate-700 transition hover:text-teal-700">Home</a>
      <a href="/shop" class="text-sm font-semibold text-slate-700 transition hover:text-teal-700">Shop</a>

      <% if (user) { %>
        <a href="/cart" class="text-sm font-semibold text-slate-700 transition hover:text-teal-700">Cart</a>
        <a href="/orders" class="text-sm font-semibold text-slate-700 transition hover:text-teal-700">Orders</a>
        <a href="/register/logout" class="rounded-full bg-slate-900 px-5 py-2.5 text-sm font-bold text-white transition hover:bg-slate-800">
          Logout
        </a>
      <% } else { %>
        <button type="button" data-open-modal="register" class="text-sm font-semibold text-slate-700 transition hover:text-teal-700">
          Register
        </button>

        <button type="button" data-open-modal="user-login" class="rounded-full bg-teal-700 px-5 py-2.5 text-sm font-bold text-white transition hover:bg-teal-800">
          Login
        </button>

        <button type="button" data-open-modal="admin-login" class="rounded-full border border-slate-300 px-5 py-2.5 text-sm font-bold text-slate-900 transition hover:bg-slate-50">
          Admin Login
        </button>
      <% } %>
    </nav>

    <button id="mobileMenuBtn" type="button" class="inline-flex items-center justify-center rounded-xl border border-slate-200 p-3 text-slate-700 md:hidden">
      <i class="fas fa-bars"></i>
    </button>
  </div>

  <div id="mobileMenu" class="hidden border-t border-slate-200 bg-white md:hidden">
    <div class="mx-auto flex max-w-7xl flex-col gap-3 px-4 py-4 sm:px-6">
      <a href="/" class="text-sm font-semibold text-slate-700">Home</a>
      <a href="/shop" class="text-sm font-semibold text-slate-700">Shop</a>

      <% if (user) { %>
        <a href="/cart" class="text-sm font-semibold text-slate-700">Cart</a>
        <a href="/orders" class="text-sm font-semibold text-slate-700">Orders</a>
        <a href="/register/logout" class="rounded-xl bg-slate-900 px-4 py-3 text-center text-sm font-bold text-white">
          Logout
        </a>
      <% } else { %>
        <button type="button" data-open-modal="register" class="rounded-xl border border-slate-300 px-4 py-3 text-sm font-semibold text-slate-700">
          Register
        </button>

        <button type="button" data-open-modal="user-login" class="rounded-xl bg-teal-700 px-4 py-3 text-sm font-bold text-white">
          Login
        </button>

        <button type="button" data-open-modal="admin-login" class="rounded-xl bg-slate-900 px-4 py-3 text-sm font-bold text-white">
          Admin Login
        </button>
      <% } %>
    </div>
  </div>
</header>